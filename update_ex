#!/usr/bin/env python3
from __future__ import annotations

import argparse
import datetime as dt
import re
from dataclasses import dataclass
from pathlib import Path
from typing import List, Optional, Dict, Tuple

from openpyxl import Workbook
from openpyxl.styles import Font, Alignment, PatternFill, Border, Side


# ---------- Deep Scan Patterns ----------
DB_OK_STR = "database successfully generated"
ERR_PATTERN = re.compile(r"Error-\[", re.IGNORECASE)

# This pattern is now very aggressive to catch SVA in the middle of lines
# It catches: UVM_ERROR, UVM_FATAL, SVA checker: ERROR, Assertion Failed, SVA Error, etc.
CHECKER_PATTERN = re.compile(
    r"(\bUVM_ERROR\b|\bUVM_FATAL\b|SVA.*ERROR|SVA.*FAIL|\bASSERTION.*FAIL\b)", 
    re.IGNORECASE
)


@dataclass
class CompileResult:
    lp: str
    status: str
    log_path: Optional[Path]
    errors: List[str]
    chosen_dir: Optional[str]


@dataclass
class TestResult:
    test_dir: str
    status: str
    log_messages: List[str]
    log_path: Optional[Path]


# ----------------- Log helpers -----------------
def safe_read_lines(log_path: Path) -> List[str]:
    """Reads the entire log file to ensure errors in the middle are not missed."""
    try:
        if not log_path.exists():
            return []
        # We use 'errors="replace"' to handle non-ascii characters often found in logs
        with log_path.open("r", encoding="utf-8", errors="replace") as f:
            return f.readlines()
    except Exception:
        # Fallback to binary if encoding fails
        try:
            with log_path.open("rb") as f:
                return f.read().decode(errors="replace").splitlines()
        except:
            return []


def extract_checker_messages(lines: List[str], max_errors: int = 100) -> List[str]:
    """Scans every single line for UVM or SVA errors."""
    msgs: List[str] = []
    for line in lines:
        if CHECKER_PATTERN.search(line):
            msgs.append(line.strip())
        if len(msgs) >= max_errors:
            break
    return msgs


# ----------------- Discovery logic -----------------
def discover_configs(reg_root: Path) -> List[Path]:
    if not reg_root.is_dir():
        return []
    configs = []
    for p in reg_root.iterdir():
        if p.is_dir() and ("uio" in p.name.lower()) and (p / "sim").is_dir():
            configs.append(p)
    return sorted(configs, key=lambda x: x.name)


def find_compile_dirs(sim_dir: Path) -> List[Path]:
    if not sim_dir.is_dir():
        return []
    return [p for p in sim_dir.iterdir() if p.is_dir() and p.name.startswith("compile_dw_")]


def classify_lp_from_dirname(name: str) -> Optional[str]:
    n = name.lower()
    if "vdut" in n: return "VDUT"
    if "vip" in n: return "VIP"
    return None


def pick_newest(paths: List[Path]) -> Optional[Path]:
    return max(paths, key=lambda p: p.stat().st_mtime) if paths else None


def compile_status_for_lp(sim_dir: Path, lp: str) -> CompileResult:
    compile_dirs = find_compile_dirs(sim_dir)
    candidates = [d for d in compile_dirs if classify_lp_from_dirname(d.name) == lp]
    chosen = pick_newest(candidates)

    if chosen is None:
        return CompileResult(lp=lp, status="NA", log_path=None, errors=[], chosen_dir=None)

    log_path = chosen / "test.log"
    lines = safe_read_lines(log_path)

    # Check for success string in the last few lines
    success = False
    for l in lines[-5:]:
        if DB_OK_STR in l.lower():
            success = True
            break

    if success:
        return CompileResult(lp=lp, status="PASS", log_path=log_path, errors=[], chosen_dir=chosen.name)

    errs = [l.strip() for l in lines if ERR_PATTERN.search(l)][:20]
    return CompileResult(lp=lp, status="FAIL", log_path=log_path, errors=errs, chosen_dir=chosen.name)


def parse_test_results(sim_dir: Path) -> List[TestResult]:
    """Finds all test directories and scans logs for failures."""
    results: List[TestResult] = []
    
    # Identify test folders (those with 'vtb' and not 'compile')
    test_paths = [p for p in sim_dir.iterdir() if p.is_dir() and "vtb" in p.name.lower() and not p.name.startswith("compile")]
    
    for tdir in sorted(test_paths, key=lambda x: x.name):
        log_path = tdir / "test.log"
        found_msgs = []
        
        # 1. SCAN LOG (Deep scan)
        if log_path.exists():
            lines = safe_read_lines(log_path)
            found_msgs = extract_checker_messages(lines)

        # 2. DETERMINE STATUS
        if found_msgs:
            state = "FAIL"
        elif (tdir / "passed").exists():
            state = "PASS"
        elif (tdir / "failed").exists():
            state = "FAIL"
            found_msgs = ["(No error text found, but 'failed' marker exists)"]
        elif (tdir / "compile_passed").exists():
            state = "RUNNING"
        else:
            state = "UNKNOWN"

        results.append(TestResult(
            test_dir=tdir.name,
            status=state,
            log_messages=found_msgs,
            log_path=log_path if log_path.exists() else None
        ))
    return results


# ----------------- Excel & Formatting -----------------
def write_excel(out_path: Path, configs_data: Dict[str, Dict]) -> None:
    wb = Workbook()
    ws = wb.active
    ws.title = "Regression Summary"

    # Styles
    hdr_f = Font(bold=True, color="FFFFFF")
    hdr_fill = PatternFill("solid", fgColor="4F81BD")
    center = Alignment(vertical="center", horizontal="center", wrap_text=True)
    top_left = Alignment(vertical="top", horizontal="left", wrap_text=True)
    border = Border(left=Side(style="thin"), right=Side(style="thin"), top=Side(style="thin"), bottom=Side(style="thin"))

    ws.append(["CONFIG NAME", "LP", "SECTION", "DETAILS"])
    for cell in ws[1]:
        cell.font, cell.fill, cell.alignment, cell.border = hdr_f, hdr_fill, center, border

    row = 2
    for cfg in sorted(configs_data.keys()):
        start_cfg = row
        for lp in ["VDUT", "VIP"]:
            start_lp = row
            
            # Compilation
            comp_txt = configs_data[cfg]["comp_cells"][lp]
            ws.append([cfg, lp, "Compilation", comp_txt])
            c = ws.cell(row=row, column=4)
            c.fill = PatternFill("solid", fgColor="FFC7CE" if "FAIL" in comp_txt.upper() else "C6EFCE")
            row += 1

            # Simulation
            sim_txt = configs_data[cfg]["run_cells"][lp]
            ws.append(["", "", "Simulation", sim_txt])
            c = ws.cell(row=row, column=4)
            # Color logic for Sim
            if "FAILURES (UVM/SVA):" in sim_txt.upper(): c.fill = PatternFill("solid", fgColor="FFC7CE")
            elif "RUNNING=" in sim_txt and "RUNNING=0" not in sim_txt: c.fill = PatternFill("solid", fgColor="FFF2CC")
            elif "PASS=" in sim_txt: c.fill = PatternFill("solid", fgColor="C6EFCE")
            row += 1

            ws.merge_cells(start_row=start_lp, start_column=2, end_row=row-1, end_column=2)
        
        ws.merge_cells(start_row=start_cfg, start_column=1, end_row=row-1, end_column=1)
        ws.append([]) # Spacer row
        row += 1

    # Final formatting
    for r in range(1, ws.max_row + 1):
        for col in range(1, 5):
            cell = ws.cell(row=r, column=col)
            cell.border = border
            cell.alignment = center if col < 4 else top_left

    ws.column_dimensions["A"].width = 30
    ws.column_dimensions["B"].width = 10
    ws.column_dimensions["C"].width = 15
    ws.column_dimensions["D"].width = 110
    wb.save(out_path)


def build_run_cell(today: str, tests: List[TestResult], clean: bool) -> str:
    if not clean: return f"{today}\nSKIPPED: Compilation failed."
    if not tests: return f"{today}\nNo tests found."

    p, f, r, u = sum(t.status=="PASS" for t in tests), sum(t.status=="FAIL" for t in tests), \
                 sum(t.status=="RUNNING" for t in tests), sum(t.status=="UNKNOWN" for t in tests)
    
    lines = [today, f"Summary: TOTAL={len(tests)} PASS={p} FAIL={f} RUNNING={r} UNKNOWN={u}"]
    
    fail_list = [t for t in tests if t.status == "FAIL"]
    if fail_list:
        lines.append("\nFAILURES (UVM/SVA):")
        for i, t in enumerate(fail_list, 1):
            lines.append(f"{i}) {t.test_dir}")
            for j, msg in enumerate(t.log_messages[:10], 1): # Max 10 msgs per test
                lines.append(f"   {j}. {msg}")
    
    return "\n".join(lines)


def main():
    parser = argparse.ArgumentParser()
    parser.add_argument("path", help="Regression root path")
    parser.add_argument("-o", "--out", help="Output file name")
    args = parser.parse_args()

    root = Path(args.path).resolve()
    output = Path(args.out).resolve() if args.out else root / "regression_summary.xlsx"
    today = dt.date.today().isoformat()

    configs = discover_configs(root)
    data = {}

    for cfg in configs:
        sim = cfg / "sim"
        vdut_c = compile_status_for_lp(sim, "VDUT")
        vip_c = compile_status_for_lp(sim, "VIP")
        
        is_clean = (vdut_c.status == "PASS" and vip_c.status == "PASS")
        tests = parse_test_results(sim) if is_clean else []

        data[cfg.name] = {
            "comp_cells": {
                "VDUT": f"{today}\nStatus: {vdut_c.status}\nDir: {vdut_c.chosen_dir}\n" + "\n".join(vdut_c.errors),
                "VIP": f"{today}\nStatus: {vip_c.status}\nDir: {vip_c.chosen_dir}\n" + "\n".join(vip_c.errors),
            },
            "run_cells": {
                "VDUT": build_run_cell(today, tests, is_clean),
                "VIP": build_run_cell(today, tests, is_clean),
            }
        }

    write_excel(output, data)
    print(f"Report generated successfully: {output}")

if __name__ == "__main__":
    main()
